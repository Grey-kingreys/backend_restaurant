
#  .env.example — Restaurant Manager Pro (backend DRF)
#  Copier ce fichier en .env et remplir les valeurs
#  cp .env.example .env


# DJANGO

SECRET_KEY=changez-moi-avec-une-vraie-cle-secrete
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1


# BASE DE DONNÉES — PostgreSQL

DB_NAME=backend_db
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable
# En production (Neon.tech) : DB_SSLMODE=require


# JWT

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7


# CORS — origines autorisées
# Séparer par des virgules, sans espaces

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080


# EMAIL (pour les rapports Celery)
# Utiliser un mot de passe d'application Gmail
# https://myaccount.google.com/apppasswords


EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=votre@email.com
REPORT_EMAIL_TO=admin@restaurant.com


# REDIS + CELERY (Phase 8)

REDIS_URL=redis://localhost:6379/0


# PRODUCTION UNIQUEMENT (Render.com)
# RENDER_EXTERNAL_HOSTNAME=votre-app.onrender.com
